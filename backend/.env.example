# ==============================================================
# EquityLens – Backend Environment Variables
# INSTRUCTIONS: On the Azure VM, run:
#   cp .env.example .env
#   nano .env           ← then fill in SECRET_KEY
# ==============================================================

# ── Django ────────────────────────────────────────────────────
# REQUIRED: Generate a unique key. Run this command to create one:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_YOUR_GENERATED_SECRET_KEY

# Keep DEBUG=False in production (never True on a live server)
DEBUG=False

# ── Domain / Host ─────────────────────────────────────────────
ALLOWED_HOSTS=euitylens.duckdns.org,www.euitylens.duckdns.org,localhost,127.0.0.1

# ── CORS / CSRF ───────────────────────────────────────────────
# These must exactly match the scheme+domain your frontend is served on
CORS_ALLOWED_ORIGINS=https://euitylens.duckdns.org
CSRF_TRUSTED_ORIGINS=https://euitylens.duckdns.org

# ── Database (SQLite is fine for single-server deployment) ────
# Leave these commented out → SQLite will be used automatically.
# Uncomment ONLY if you switch to PostgreSQL in the future.
# DB_NAME=equitylens
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
